@using Microsoft.AspNetCore.Components.Routing
@using FitLife.Frontend.Services
@inject NavigationManager Navigation
@inject AuthService Auth

<nav class="top-nav">
    <div class="nav-inner">
        <a href="/dashboard" class="nav-brand">
            <div class="nav-logo">FL</div>
            <span class="nav-brand-text">FitLife</span>
        </a>

        <div class="nav-links">
            <NavLink class="nav-link-item" href="dashboard" Match="NavLinkMatch.All">
                <i class="bi bi-house-door"></i> Dashboard
            </NavLink>
            <NavLink class="nav-link-item" href="holdoversigt">
                <i class="bi bi-calendar2-week"></i> Hold
            </NavLink>
            <NavLink class="nav-link-item" href="livestream">
                <i class="bi bi-camera-video"></i> Livestream
            </NavLink>
            <NavLink class="nav-link-item" href="community">
                <i class="bi bi-people"></i> Community
            </NavLink>
            <NavLink class="nav-link-item" href="traeningslog">
                <i class="bi bi-clipboard-check"></i> Træningslog
            </NavLink>
            <NavLink class="nav-link-item" href="personlig-traening">
                <i class="bi bi-person-arms-up"></i> Personlig træning
            </NavLink>
            @if (_isTrainer)
            {
                <NavLink class="nav-link-item" href="admin">
                    <i class="bi bi-gear"></i> Admin
                </NavLink>
            }
        </div>

        <div class="nav-avatar"
             role="button"
             tabindex="0"
             title="Indstillinger"
             aria-label="Åbn indstillinger"
             @onclick='() => Navigation.NavigateTo("/indstillinger")'>
            @_avatarInitials
        </div>
    </div>
</nav>

@code {
    private bool _isTrainer;
    private string _avatarInitials = "U";

    protected override async Task OnInitializedAsync()
    {
        var role = await Auth.GetRoleAsync();
        _isTrainer = role == "Trainer";
        _avatarInitials = await GetAvatarInitialsAsync();
    }

    private async Task<string> GetAvatarInitialsAsync()
    {
        try
        {
            var userName = await Auth.GetUserNameAsync();
            return GetInitials(userName);
        }
        catch
        {
            return "U";
        }
    }

    private static string GetInitials(string? fullName)
    {
        if (string.IsNullOrWhiteSpace(fullName))
            return "U";

        var parts = fullName.Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 0)
            return "U";

        if (parts.Length == 1)
            return parts[0][0].ToString().ToUpperInvariant();

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }
}
