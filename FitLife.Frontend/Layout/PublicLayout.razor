@inherits LayoutComponentBase
@inject NavigationManager Navigation

<div class="public-layout">
    @if (!IsLoginPage)
    {
        <header class="public-header">
            <nav class="public-nav" aria-label="Public navigation">
                <a href="/home" class="public-brand">
                    <div class="public-logo">FL</div>
                    <span>FitLife Digital</span>
                </a>

                <div class="public-actions">
                    <a class="public-link" href="/login">Log ind</a>
                    <a class="public-cta" href="/login">Kom i gang</a>
                </div>
            </nav>
        </header>
    }

    <main class="public-main @(IsLoginPage ? "login-main" : null)">
        @Body
    </main>
</div>

@code {
    private bool IsLoginPage
    {
        get
        {
            var path = Navigation
                .ToBaseRelativePath(Navigation.Uri)
                .Split('?', '#')[0]
                .Trim('/');

            return string.Equals(path, "login", StringComparison.OrdinalIgnoreCase);
        }
    }
}
