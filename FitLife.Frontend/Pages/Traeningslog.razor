@page "/traeningslog"
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject TrainingLogService TrainingLogService

<div class="tl-page">
    <div class="tl-header">
        <h1>Træningslog</h1>
        <p class="tl-subtitle">Opret programmer og log din træning ét sted</p>
    </div>

    @if (activeView == "overview")
    {
        <div class="tl-section">
            <div class="tl-section-header">
                <h2>Mine træningsprogrammer</h2>
                <button class="tl-create-btn" @onclick='() => activeView = "create"'>+ Opret nyt program</button>
            </div>

            @if (isLoading)
            {
                <p class="tl-loading">Henter programmer...</p>
            }
            else if (!programs.Any())
            {
                <p class="tl-loading">Du har ingen programmer endnu.</p>
            }
            else
            {
                <div class="tl-program-grid">
                    @foreach (var program in programs)
                    {
                        <div class="tl-program-card" @onclick="() => SelectProgram(program)">
                            <div class="tl-program-icon"><i class="bi bi-lightning-charge"></i></div>
                            <div class="tl-program-info">
                                <h3>@program.Name</h3>
                                <p>@program.ExerciseCount øvelser</p>
                            </div>
                            <span class="tl-chevron">›</span>
                        </div>
                    }
                </div>
            }
        </div>
    }

    @if (activeView == "create")
    {
        <div class="tl-card">
            <h2>Nyt træningsprogram</h2>

            <div class="tl-form-group">
                <label>Programnavn</label>
                <input type="text" @bind="newProgramName" placeholder="F.eks. Min push dag" class="tl-input" />
            </div>

            <div class="tl-exercise-section">
                <div class="tl-exercise-header">
                    <h3>Øvelser</h3>
                    <button class="tl-add-exercise-btn" @onclick="AddExercise">+ Tilføj øvelse</button>
                </div>

                @if (newExercises.Any())
                {
                    <div class="tl-exercise-table-header">
                        <span>Øvelse</span><span>Sæt</span><span>Reps</span><span>Kg</span><span></span>
                    </div>
                    @foreach (var ex in newExercises)
                    {
                        <div class="tl-exercise-row">
                            <input type="text" @bind="ex.Name" placeholder="Øvelsens navn" class="tl-input" />
                            <input type="number" @bind="ex.Sets" min="1" class="tl-input tl-input-sm" />
                            <input type="number" @bind="ex.Reps" min="1" class="tl-input tl-input-sm" />
                            <input type="number" @bind="ex.WeightKg" min="0.5" step="0.5" class="tl-input tl-input-sm" />
                            <button class="tl-remove-btn" @onclick="() => newExercises.Remove(ex)">✕</button>
                        </div>
                    }
                }
                else
                {
                    <p class="tl-loading">Ingen øvelser tilføjet endnu.</p>
                }
            </div>

            <div class="tl-actions">
                <button class="tl-secondary-btn" @onclick='() => activeView = "overview"'>Annuller</button>
                <button class="tl-primary-btn" @onclick="SaveProgram" disabled="@(string.IsNullOrWhiteSpace(newProgramName))">Gem program</button>
            </div>
        </div>
    }

    @if (activeView == "log" && selectedProgram is not null)
    {
        <div class="tl-card">
            <div class="tl-log-header">
                <div>
                    @if (isEditingName)
                    {
                        <input type="text" @bind="editProgramName" class="tl-input" />
                        <button class="tl-primary-btn" @onclick="SaveProgramName">Gem navn</button>
                        <button class="tl-secondary-btn" @onclick="() => isEditingName = false">Annuller</button>
                    }
                    else
                    {
                        <h2>@selectedProgram.Name <button class="tl-edit-btn" @onclick="StartEditName"><i class="bi bi-pencil"></i></button></h2>
                        <p class="tl-subtitle">Log din træning</p>
                    }
                </div>
                <button class="tl-secondary-btn" @onclick='() => activeView = "overview"'>Tilbage til oversigt</button>
            </div>

            <div class="tl-exercise-section">
                <div class="tl-exercise-header">
                    <h3>Øvelser</h3>
                    <button class="tl-add-exercise-btn" @onclick="StartAddExercise">+ Tilføj øvelse</button>
                </div>

                @if (selectedProgram.Exercises.Any() || isAddingExercise)
                {
                    <div class="tl-exercise-table-header">
                        <span>Øvelse</span><span>Sæt</span><span>Reps</span><span>Kg</span><span></span>
                    </div>
                }

                @foreach (var ex in selectedProgram.Exercises)
                {
                    @if (editingExerciseId == ex.Id)
                    {
                        <div class="tl-exercise-row">
                            <input type="text" @bind="editExercise.Name" class="tl-input" />
                            <input type="number" @bind="editExercise.Sets" min="1" class="tl-input tl-input-sm" />
                            <input type="number" @bind="editExercise.Reps" min="1" class="tl-input tl-input-sm" />
                            <input type="number" @bind="editExercise.WeightKg" min="0.5" step="0.5" class="tl-input tl-input-sm" />
                            <div style="display:flex; gap:0.25rem; align-items:center;">
                                <button class="tl-save-btn" @onclick="() => SaveExercise(ex.Id)"><i class="bi bi-check-lg"></i></button>
                                <button class="tl-remove-btn" @onclick="CancelEditExercise">✕</button>
                            </div>
                        </div>
                    }
                    else
                    {
                        <div class="tl-exercise-log-row">
                            <span class="tl-exercise-name">@ex.Name</span>
                            <span>@ex.Sets</span>
                            <span>@ex.Reps</span>
                            <span>@(ex.WeightKg?.ToString() ?? "—")</span>
                            <button class="tl-edit-btn" @onclick="() => StartEditExercise(ex)"><i class="bi bi-pencil"></i></button>
                        </div>
                    }
                }

                @if (isAddingExercise)
                {
                    <div class="tl-exercise-row">
                        <input type="text" @bind="newExerciseName" placeholder="Øvelsens navn" class="tl-input" />
                        <input type="number" @bind="newExerciseSets" min="1" class="tl-input tl-input-sm" />
                        <input type="number" @bind="newExerciseReps" min="1" class="tl-input tl-input-sm" />
                        <input type="number" @bind="newExerciseWeightKg" min="0.5" step="0.5" class="tl-input tl-input-sm" />
                        <div style="display:flex; gap:0.25rem; align-items:center;">
                            <button class="tl-save-btn" @onclick="SaveNewExercise"><i class="bi bi-check-lg"></i></button>
                            <button class="tl-remove-btn" @onclick="() => isAddingExercise = false">✕</button>
                        </div>
                    </div>
                }

                @if (!selectedProgram.Exercises.Any() && !isAddingExercise)
                {
                    <p class="tl-loading">Ingen øvelser i dette program.</p>
                }
            </div>

            <div class="tl-actions">
                <button class="tl-primary-btn" @onclick='() => activeView = "overview"'>Tilbage til oversigt</button>
            </div>
        </div>
    }
</div>

@code {
    private string activeView = "overview";
    private List<WorkoutProgram> programs = [];
    private WorkoutProgram? selectedProgram;
    private bool isLoading = true;

    private string newProgramName = string.Empty;
    private List<Exercise> newExercises = [];

    private bool isEditingName = false;
    private string editProgramName = string.Empty;

    private Guid? editingExerciseId = null;
    private Exercise editExercise = new();

    private bool isAddingExercise = false;
    private string newExerciseName = string.Empty;
    private int newExerciseSets = 3;
    private int newExerciseReps = 10;
    private decimal? newExerciseWeightKg = null;

    protected override async Task OnInitializedAsync()
    {
        programs = await TrainingLogService.GetProgramsAsync();
        isLoading = false;
    }

    private async Task SelectProgram(WorkoutProgram program)
    {
        programs = await TrainingLogService.GetProgramsAsync();
        selectedProgram = programs.FirstOrDefault(p => p.Id == program.Id);
        activeView = "log";
    }

    private void AddExercise()
    {
        newExercises.Add(new Exercise { Sets = 3, Reps = 10 });
    }

    private async Task SaveProgram()
    {
        if (string.IsNullOrWhiteSpace(newProgramName)) return;

        var program = await TrainingLogService.CreateProgramAsync(newProgramName);
        if (program is not null)
        {
            foreach (var ex in newExercises.Where(e => !string.IsNullOrWhiteSpace(e.Name)))
                await TrainingLogService.AddExerciseAsync(program.Id, ex.Name, ex.Sets, ex.Reps, ex.WeightKg);

            programs = await TrainingLogService.GetProgramsAsync();
            newProgramName = string.Empty;
            newExercises = [];
            activeView = "overview";
        }
    }

    private void StartEditName()
    {
        editProgramName = selectedProgram!.Name;
        isEditingName = true;
    }

    private async Task SaveProgramName()
    {
        if (selectedProgram is null || string.IsNullOrWhiteSpace(editProgramName)) return;

        var updated = await TrainingLogService.UpdateProgramNameAsync(selectedProgram.Id, editProgramName);
        if (updated is not null)
        {
            selectedProgram.Name = updated.Name;
            programs = await TrainingLogService.GetProgramsAsync();
        }
        isEditingName = false;
    }

    private void StartEditExercise(Exercise ex)
    {
        editingExerciseId = ex.Id;
        editExercise = new Exercise
        {
            Id = ex.Id,
            Name = ex.Name,
            Sets = ex.Sets,
            Reps = ex.Reps,
            WeightKg = ex.WeightKg
        };
    }

    private async Task SaveExercise(Guid exerciseId)
    {
        if (selectedProgram is null) return;

        var updated = await TrainingLogService.UpdateExerciseAsync(
            selectedProgram.Id, exerciseId,
            editExercise.Name, editExercise.Sets, editExercise.Reps, editExercise.WeightKg);

        if (updated is not null)
            selectedProgram = updated;

        editingExerciseId = null;
    }

    private void CancelEditExercise()
    {
        editingExerciseId = null;
    }

    private void StartAddExercise()
    {
        isAddingExercise = true;
        newExerciseName = string.Empty;
        newExerciseSets = 3;
        newExerciseReps = 10;
        newExerciseWeightKg = null;
    }

    private async Task SaveNewExercise()
    {
        if (selectedProgram is null || string.IsNullOrWhiteSpace(newExerciseName)) return;

        var updated = await TrainingLogService.AddExerciseAsync(
            selectedProgram.Id, newExerciseName, newExerciseSets, newExerciseReps, newExerciseWeightKg);

        if (updated is not null)
            selectedProgram = updated;

        isAddingExercise = false;
    }
}