@page "/personlig-traening"
@using FitLife.Frontend.Models
@using FitLife.Frontend.Services
@inject TrainerService TrainerService

<div class="pt-page">
    <div class="pt-hero">
        <div class="pt-hero-content">
            <h1>Personlig træning</h1>
            <p class="pt-subtitle">Få professionel vejledning til at nå dine mål</p>
        </div>
    </div>

    <div class="pt-banner">
        <div class="pt-banner-inner">
            <div class="pt-banner-text">
                <h2>Opnå dine mål hurtigere</h2>
                <p>Personlig træning giver dig den vejledning og motivation, du har brug for. Arbejd med eksperter der forstår din rejse.</p>
                <div class="pt-benefits">
                    <div class="pt-benefits-col">
                        <div class="pt-benefit">• Skræddersyet træningsplan til dine mål</div>
                        <div class="pt-benefit">• Fleksible tider der passer dig</div>
                        <div class="pt-benefit">• Kostplan og livsstilsrådgivning</div>
                    </div>
                    <div class="pt-benefits-col">
                        <div class="pt-benefit">• En-til-en vejledning og feedback</div>
                        <div class="pt-benefit">• Motivation og ansvarlighed</div>
                        <div class="pt-benefit">• Tilgængelig på alle FitLife centre</div>
                    </div>
                </div>
            </div>
            <div class="pt-banner-image" style="background-image: url('https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=800&q=80')"></div>
        </div>
    </div>

    <div class="pt-trainers-section">
        <h2>Mød vores trænere</h2>

        @if (isLoading)
        {
            <p class="pt-loading">Henter trænere...</p>
        }
        else if (!trainers.Any())
        {
            <p class="pt-loading">Ingen trænere fundet.</p>
        }
        else
        {
            <div class="pt-trainer-grid">
                @foreach (var trainer in trainers)
                {
                    <div class="pt-trainer-card">
                        <div class="pt-trainer-image" style="background-image: url('@GetTrainerImage(trainers.IndexOf(trainer))')">
                            <div class="pt-rating">⭐ @trainer.Rating</div>
                        </div>
                        <div class="pt-trainer-body">
                            <h3>@trainer.Name</h3>
                            <div class="pt-specialties">
                                @foreach (var specialty in trainer.Specialties)
                                {
                                    <span class="pt-specialty-badge">@specialty</span>
                                }
                            </div>
                            <div class="pt-trainer-meta">
                                <span>🏅 @trainer.ExperienceYears år erfaring</span>
                                <span>🕐 @trainer.Sessions+ sessions</span>
                            </div>
                            <button class="pt-book-btn">Book session</button>
                        </div>
                    </div>
                }
            </div>
        }
    </div>
</div>

@code {
    private List<PersonalTrainer> trainers = [];
    private bool isLoading = true;

    protected override async Task OnInitializedAsync()
    {
        trainers = await TrainerService.GetAllAsync();
        isLoading = false;
    }
    
    private static readonly List<string> _trainerImages =
    [
        "https://images.unsplash.com/photo-1571019613454-1cb2f99b2d8b?w=600&q=80",
        "https://images.unsplash.com/photo-1534438327276-14e5300c3a48?w=600&q=80",
        "https://images.unsplash.com/photo-1544367567-0f2fcb009e0b?w=600&q=80",
        "https://images.unsplash.com/photo-1583454110551-21f2fa2afe61?w=600&q=80",
        "https://images.unsplash.com/photo-1549060279-7e168fcee0c2?w=600&q=80",
    ];

    private string GetTrainerImage(int index) => _trainerImages[index % _trainerImages.Count];
}