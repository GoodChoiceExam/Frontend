@page "/login"
@layout PublicLayout
@using FitLife.Frontend.Services
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Log ind | FitLife Digital</PageTitle>

<main class="login-page">
    <section class="login-panel" aria-labelledby="login-title">
        <a class="back-link" href="/home" aria-label="Tilbage til forsiden">← Tilbage</a>

        <h1 id="login-title">Log ind</h1>
        <p class="login-subtitle">Velkommen tilbage til FitLife Digital</p>

        <div class="login-card">
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="error-message">@_error</p>
            }

            <EditForm class="login-form" Model="_model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <div class="form-field">
                    <label for="email">E-mail</label>
                    <InputText id="email" class="form-input" type="email" placeholder="din@email.dk" @bind-Value="_model.Email" />
                </div>
                <div class="form-field">
                    <label for="password">Adgangskode</label>
                    <InputText id="password" class="form-input" placeholder="••••••••" @bind-Value="_model.Password" type="password" />
                </div>
                <button class="login-button" type="submit" disabled="@_loading">
                    @(_loading ? "Logger ind..." : "Log ind")
                </button>
            </EditForm>

            <p class="signup-text">Har du ikke en konto? <a href="/login">Kom i gang</a></p>
        </div>
    </section>
</main>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;

        var success = await Auth.LoginAsync(_model.Email, _model.Password);
        if (success)
            Nav.NavigateTo("/");
        else
            _error = "Forkert email eller password";

        _loading = false;
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
