@page "/login"
@layout PublicLayout
@using FitLife.Frontend.Services
@inject AuthService Auth
@inject NavigationManager Nav

<PageTitle>Log ind | FitLife</PageTitle>

<main class="fitlife-login">
    <section class="fitlife-login-panel" aria-labelledby="login-title">
        <a class="fitlife-back-link" href="/">← Tilbage</a>

        <div class="fitlife-login-heading">
            <h1 id="login-title">Log ind</h1>
            <p>Velkommen tilbage til FitLife</p>
        </div>

        <div class="fitlife-login-card">
            @if (!string.IsNullOrEmpty(_error))
            {
                <p class="fitlife-login-error">@_error</p>
            }

            <EditForm class="fitlife-login-form" Model="_model" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />
                <div class="fitlife-form-field">
                    <label for="email">E-mail</label>
                    <InputText id="email" class="fitlife-form-input" type="email" placeholder="din@email.dk" @bind-Value="_model.Email" />
                </div>
                <div class="fitlife-form-field">
                    <label for="password">Adgangskode</label>
                    <InputText id="password" class="fitlife-form-input" type="password" placeholder="••••••••" @bind-Value="_model.Password" />
                </div>
                <button class="fitlife-login-button" type="submit" disabled="@_loading">
                    @(_loading ? "Logger ind..." : "Log ind")
                </button>
                <p class="fitlife-signup-text">Har du ikke en konto? <a href="/opret-profil">Kom i gang</a></p>
            </EditForm>
        </div>
    </section>
</main>

@code {
    private readonly LoginModel _model = new();
    private string? _error;
    private bool _loading;

    private async Task HandleLogin()
    {
        _loading = true;
        _error = null;

        var success = await Auth.LoginAsync(_model.Email, _model.Password);
        if (success)
            Nav.NavigateTo("/dashboard");
        else
            _error = "Forkert email eller password";

        _loading = false;
    }

    private class LoginModel
    {
        public string Email { get; set; } = string.Empty;
        public string Password { get; set; } = string.Empty;
    }
}
