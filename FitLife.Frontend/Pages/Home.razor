@page "/"
@page "/home"
@layout PublicLayout

<PageTitle>FitLife</PageTitle>

<main class="home-page">
    <section class="hero-section" aria-labelledby="hero-title">
        <div class="hero-content">
            <p class="eyebrow">FitLife</p>
            <h1 id="hero-title">Træning der passer til din hverdag</h1>
            <p class="hero-text">
                Saml centertræning, livestream, community og dine fremskridt i én enkel platform,
                så du kan træne fleksibelt og holde motivationen hele vejen.
            </p>
            <div class="hero-actions" aria-label="Primære handlinger">
                <a class="btn btn-primary" href="/opret-profil">Kom i gang</a>
            </div>
        </div>

        <div class="hero-visual" aria-label="FitLife træningsoplevelse">
            <div class="member-stat-card">
                <strong>8,400+</strong>
                <span>Aktive medlemmer</span>
            </div>
        </div>
    </section>

    <section class="features-section" aria-labelledby="features-title">
        <div class="section-heading">
            <p class="eyebrow">Platformen</p>
            <h2 id="features-title">Alt samlet omkring din træning</h2>
        </div>

        <div class="feature-grid">
            <article class="feature-card">
                <div class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 3v3M17 3v3M4 9h16M6 5h12a2 2 0 0 1 2 2v11a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V7a2 2 0 0 1 2-2Z" />
                    </svg>
                </div>
                <h3>Hold</h3>
                <p>Find og book hold, der matcher dit niveau, din kalender og den træningsform du bedst kan lide.</p>
            </article>

            <article class="feature-card">
                <div class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="m15 10 5-3v10l-5-3v-4ZM4 7h9a2 2 0 0 1 2 2v6a2 2 0 0 1-2 2H4V7Z" />
                    </svg>
                </div>
                <h3>Livestream</h3>
                <p>Deltag i live træning hjemmefra, når hverdagen kræver mere frihed og mindre transporttid.</p>
            </article>

            <article class="feature-card">
                <div class="feature-icon" aria-hidden="true">
                    <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M16 11a4 4 0 1 0-8 0M4 20a8 8 0 0 1 16 0M18 8a3 3 0 0 1 3 3M21 20a6 6 0 0 0-3-5.2M6 8a3 3 0 0 0-3 3M3 20a6 6 0 0 1 3-5.2" />
                    </svg>
                </div>
                <h3>Community</h3>
                <p>Få motivation fra andre medlemmer, del fremskridt og føl dig som en del af et aktivt fællesskab.</p>
            </article>
        </div>
    </section>

    <section class="why-section" aria-labelledby="why-title">
        <div class="why-visual" aria-hidden="true">
            <div class="wellness-panel">
                <span>FitLife center</span>
                <strong>Åbent 05.00 - 23.00</strong>
                <p>Fleksibel adgang til træning, hold og faciliteter.</p>
            </div>
        </div>

        <div class="why-content">
            <p class="eyebrow">Derfor vælger medlemmerne os</p>
            <h2 id="why-title">Hvorfor FitLife?</h2>
            <ul class="benefit-list">
                <li>
                    <span aria-hidden="true"></span>
                    <div>
                        <strong>Fleksibel træning</strong>
                        <p>Træn i centeret, på hold eller via livestream, når det passer ind i din dag.</p>
                    </div>
                </li>
                <li>
                    <span aria-hidden="true"></span>
                    <div>
                        <strong>Personlige mål</strong>
                        <p>Følg dine fremskridt og hold fokus på de mål, der betyder noget for dig.</p>
                    </div>
                </li>
                <li>
                    <span aria-hidden="true"></span>
                    <div>
                        <strong>Adgang til centre og faciliteter</strong>
                        <p>Brug FitLife som digital nøgle til både overblik, booking og træningsmuligheder.</p>
                    </div>
                </li>
                <li>
                    <span aria-hidden="true"></span>
                    <div>
                        <strong>Community og motivation</strong>
                        <p>Bliv støttet af et fællesskab, der gør det lettere at møde op igen i morgen.</p>
                    </div>
                </li>
            </ul>
        </div>
    </section>

    <section class="cta-section" aria-labelledby="cta-title">
        <div>
            <p class="eyebrow">Din næste træning starter her</p>
            <h2 id="cta-title">Klar til at komme i gang?</h2>
        </div>
        <a class="btn btn-primary cta-button" href="/opret-profil">Kom i gang nu</a>
    </section>

    <footer class="home-footer">
        <strong>FitLife</strong>
        <span>&copy; 2026 FitLife. Alle rettigheder forbeholdes.</span>
    </footer>
</main>
